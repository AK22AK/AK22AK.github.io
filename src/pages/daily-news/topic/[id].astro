---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Calendar from '../../../components/Calendar.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const topicsPath = path.resolve('./src/data/daily-news-topics.json');
  const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
  const topics = topicsConfig.topics;
  return topics.map((topic: any) => ({
    params: { id: topic.id },
    props: { topic },
  }));
}

const { topic } = Astro.props as {
  topic: {
    id: string; name: string; type: string; description: string;
    active: boolean; startDate?: string; endDate?: string;
    sources: Array<{id: string; name: string; url: string; frequency: string}>;
    subtopics?: Array<{id: string; name: string; description: string}>;
  }
};

const newsData = await getCollection('daily-news');
const dateEntries = newsData.filter(entry => entry.id !== 'topics');
dateEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = new URL(Astro.request.url);
const selectedDate = url.searchParams.get('date');
const availableDates = dateEntries.map(e => e.data.date);
const currentDate = selectedDate && availableDates.includes(selectedDate)
  ? selectedDate
  : (availableDates[0] || '');
const currentEntry = dateEntries.find(e => e.data.date === currentDate);
const currentItems = currentEntry?.data.items.filter(i => i.topic === topic.id) || [];
const currentTopicSummary = currentEntry?.data.topic_summaries?.find(s => s.topic === topic.id);
const currentSubtopicSummaries = currentEntry?.data.subtopic_summaries?.[topic.id] || [];
const hasSubtopics = (topic.subtopics?.length || 0) > 0;
const groupParam = hasSubtopics ? 'subtopic' : 'source';
const overviewNavTitle = hasSubtopics ? '📖 子主题导航' : '📖 来源导航';

// 跨日期取该板块所有新闻（用于 top10）
const allTopicItems: Array<{item: typeof currentItems[0]; date: string}> = [];
for (const entry of dateEntries) {
  for (const item of entry.data.items) {
    if (item.topic === topic.id) {
      allTopicItems.push({ item, date: entry.data.date });
    }
  }
}
allTopicItems.sort((a, b) => b.date.localeCompare(a.date));

// top10：去重 + 取前10
const seen = new Set();
const top10 = [];
for (const { item } of allTopicItems) {
  if (!seen.has(item.title)) {
    seen.add(item.title);
    top10.push(item);
  }
  if (top10.length >= 10) break;
}

// 按来源分组（仅当天）
const sourceGroups = new Map<string, typeof currentItems>();
for (const item of currentItems) {
  if (!sourceGroups.has(item.source)) {
    sourceGroups.set(item.source, []);
  }
  sourceGroups.get(item.source)!.push(item);
}

// 来源排序：按 topics.json 中的顺序（已按 frequency 排好）
const orderedSources = topic.sources || [];
const freqOrder = { high: 0, medium: 1, low: 2 };
const sortedSources = [...orderedSources].sort((a, b) => {
  return (freqOrder as any)[a.frequency] - (freqOrder as any)[b.frequency];
});

const UNCATEGORIZED_SUBTOPIC = {
  id: 'uncategorized',
  name: '未分类',
  description: '未能归入既有子主题的资讯',
};

const subtopicGroups = new Map<string, typeof currentItems>();
if (hasSubtopics) {
  for (const item of currentItems) {
    const subtopicId = item.subtopic || UNCATEGORIZED_SUBTOPIC.id;
    if (!subtopicGroups.has(subtopicId)) {
      subtopicGroups.set(subtopicId, []);
    }
    subtopicGroups.get(subtopicId)!.push(item);
  }
}

const orderedSubtopics = [...(topic.subtopics || [])];
if (hasSubtopics && subtopicGroups.has(UNCATEGORIZED_SUBTOPIC.id)) {
  orderedSubtopics.push(UNCATEGORIZED_SUBTOPIC);
}

// ===== 权重排序系统 =====
const BRAND_KEYWORDS = [
  '苹果', 'iPhone', 'iPad', 'Mac', '小米', '华为', '三星', 'OPPO', 'vivo',
  '谷歌', 'Pixel', '特斯拉', '比亚迪', 'OpenAI', 'ChatGPT', 'Claude',
  '英伟达', 'NVIDIA', 'AMD', '英特尔', '微软', 'Meta', 'Steam',
  '腾讯', '阿里', '字节', '百度', '网易', 'B站', '哔哩哔哩',
  '微信', '抖音', '淘宝', '京东', '拼多多',
  '马云', '马化腾', '雷军', '马斯克',
  '宁德时代', '大疆',
];

function hasBrandKeyword(title: string): boolean {
  return BRAND_KEYWORDS.some(kw => title.includes(kw));
}

function hasNumber(title: string): boolean {
  return /\d/.test(title);
}

function isMorningPost(title: string): boolean {
  const t = title.toLowerCase();
  const keywords = ['早报', '派早报', 'morning', '晨读', '今日早报'];
  return keywords.some(kw => t.includes(kw));
}

function hoursAgo(pubTime: string | undefined): number {
  if (!pubTime) return 48;
  const hasTimezone = /(?:Z|[+-]\d{2}:?\d{2})$/i.test(pubTime);
  const pub = new Date(hasTimezone ? pubTime : `${pubTime}Z`);
  if (Number.isNaN(pub.getTime())) return 48;
  const now = new Date();
  return Math.max(0, (now.getTime() - pub.getTime()) / (1000 * 60 * 60));
}

function pubTimeValue(pubTime: string | undefined): number {
  if (!pubTime) return 0;
  const hasTimezone = /(?:Z|[+-]\d{2}:?\d{2})$/i.test(pubTime);
  const pub = new Date(hasTimezone ? pubTime : `${pubTime}Z`);
  return Number.isNaN(pub.getTime()) ? 0 : pub.getTime();
}

function calcWeight(item: typeof currentItems[0]): number {
  const title = item.title;
  let weight = 0;
  if (isMorningPost(title)) weight += 1000;
  if (hasBrandKeyword(title)) weight += 10;
  if (hasNumber(title)) weight += 5;
  const h = hoursAgo(item.pub_time);
  weight += (1 / (h + 1)) * 50;
  return weight;
}

function getItemSummary(item: typeof currentItems[0]): string {
  return item.ai_summary || item.summary;
}

function getTopItems(items: typeof currentItems, count: number = 5) {
  return [...items].sort((a, b) => calcWeight(b) - calcWeight(a)).slice(0, count);
}

function shouldCollapseSummary(summary?: { summary: string; highlights: string[] }) {
  if (!summary) return false;
  return summary.summary.length > 150 || summary.highlights.length > 4;
}

// 获取展示用 items：当天权重排序 + 前一天补充
type DisplayResult = {
  items: typeof currentItems;
  hasMore: boolean;
  allItems: typeof currentItems;
  fallbackCount: number;
};

function getDisplayedItems(sourceId: string, targetCount: number = 5): DisplayResult {
  const todayItems = currentItems.filter(i => i.source === sourceId);
  const sortedToday = getTopItems(todayItems, targetCount);

  if (sortedToday.length >= targetCount) {
    return {
      items: sortedToday,
      hasMore: todayItems.length > targetCount,
      allItems: todayItems,
      fallbackCount: 0,
    };
  }

  const prevEntry = dateEntries[1];
  let fallbackItems: typeof currentItems = [];
  if (prevEntry) {
    const prevItems = prevEntry.data.items
      .filter(i => i.source === sourceId && i.topic === topic.id)
      .sort((a, b) => pubTimeValue(b.pub_time) - pubTimeValue(a.pub_time));
    const needed = targetCount - sortedToday.length;
    fallbackItems = prevItems.slice(0, needed);
  }

  // 去重：历史数据中已存在于当天的，不重复显示
  const seenUrls = new Set(todayItems.map(i => i.url));
  const seenTitles = new Set(todayItems.map(i => i.title));
  const uniqueFallback = fallbackItems.filter(item =>
    !seenUrls.has(item.url) && !seenTitles.has(item.title)
  );
  const combined = [...sortedToday, ...uniqueFallback];
  return {
    items: combined,
    hasMore: todayItems.length > targetCount,
    allItems: todayItems,
    fallbackCount: uniqueFallback.length,
  };
}

function getSubtopicSummary(subtopicId: string) {
  return currentSubtopicSummaries.find(s => s.subtopic === subtopicId);
}

function getSubtopicItems(subtopicId: string) {
  return currentItems.filter(item => (item.subtopic || UNCATEGORIZED_SUBTOPIC.id) === subtopicId);
}

function getDisplayedSubtopicItems(subtopicId: string, targetCount: number = 5): DisplayResult {
  const todayItems = getSubtopicItems(subtopicId);
  return {
    items: getTopItems(todayItems, targetCount),
    hasMore: todayItems.length > targetCount,
    allItems: todayItems,
    fallbackCount: 0,
  };
}

// 为每个来源预计算详情数据
type SourceDetail = {
  id: string;
  name: string;
  url: string;
  todayItems: typeof currentItems;
  fallbackItems: typeof currentItems;
};

const sourceDetails: SourceDetail[] = sortedSources.map(src => {
  const todayItems = currentItems.filter(i => i.source === src.id);
  let fallbackItems: typeof currentItems = [];
  if (todayItems.length < 5 && dateEntries[1]) {
    const seenUrls = new Set(todayItems.map(i => i.url));
    const seenTitles = new Set(todayItems.map(i => i.title));
    const prevItems = dateEntries[1].data.items
      .filter(i => i.source === src.id && i.topic === topic.id)
      .filter(i => !seenUrls.has(i.url) && !seenTitles.has(i.title))
      .sort((a, b) => pubTimeValue(b.pub_time) - pubTimeValue(a.pub_time));
    fallbackItems = prevItems.slice(0, 5 - todayItems.length);
  }
  return { id: src.id, name: src.name, url: src.url, todayItems, fallbackItems };
});

type SubtopicDetail = {
  id: string;
  name: string;
  summary?: { summary: string; highlights: string[] };
  todayItems: typeof currentItems;
};

const subtopicDetails: SubtopicDetail[] = orderedSubtopics.map(subtopic => ({
  id: subtopic.id,
  name: subtopic.name,
  summary: getSubtopicSummary(subtopic.id),
  todayItems: getTopItems(getSubtopicItems(subtopic.id), Number.POSITIVE_INFINITY),
}));
---

<BaseLayout title={`${topic.name} - 新闻详情 - AK22AK`} description={`AK22AK 关注的 ${topic.name} 资讯详情`} variant="news">
  <div
    class="daily-news-layout daily-news-layout--with-summary daily-news-layout--topic"
    data-group-param={groupParam}
    data-overview-nav-title={overviewNavTitle}
  >
    <!-- 左侧导航 -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <div style="margin-bottom: 1rem;">
          <a href="/daily-news/" class="back-link">← 返回新闻首页</a>
          <a href={`/daily-news/topic/${topic.id}/?date=${currentDate}`} class="back-link" id="back-to-overview" style="display: none;">← 返回 {topic.name} 概览</a>
        </div>
        <h3 class="sidebar-title" id="sidebar-title">{overviewNavTitle}</h3>
        <nav class="sidebar-nav" id="sidebar-nav">
          <a href="#top10" class="sidebar-link" id="nav-overview">
            <span class="sidebar-icon">📊</span>
            <span class="sidebar-name">概览</span>
          </a>
          {hasSubtopics ? (
            orderedSubtopics.map(subtopic => {
              const count = subtopicGroups.get(subtopic.id)?.length || 0;
              return (
                <a
                  href={`#subtopic-${subtopic.id}`}
                  class="sidebar-link nav-group nav-subtopic"
                  data-group={subtopic.id}
                >
                  <span class="sidebar-name">{subtopic.name}</span>
                  <span class="sidebar-count" data-count={count}>{count > 0 ? count : ''}</span>
                </a>
              );
            })
          ) : (
            sortedSources.map(src => {
              const count = sourceGroups.get(src.id)?.length || 0;
              return (
                <a
                  href={`#src-${src.id}`}
                  class="sidebar-link nav-group nav-source"
                  data-group={src.id}
                >
                  <span class="sidebar-name">{src.name}</span>
                  <span class="sidebar-count" data-count={count}>{count > 0 ? count : ''}</span>
                </a>
              );
            })
          )}
        </nav>
        <Calendar dates={availableDates} currentDate={currentDate} baseUrl={`/daily-news/topic/${topic.id}/`} />
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="daily-main">
      <!-- 日期切换 -->
      <div class="date-list" style="margin-bottom: 1.5rem; justify-content: flex-start;">
        {availableDates.map(date => (
          <a
            href={`/daily-news/topic/${topic.id}/?date=${date}`}
            class={`date-pill date-nav ${date === currentDate ? 'active' : ''}`}
            data-date={date}
          >
            {date}
          </a>
        ))}
      </div>

      <!-- 板块信息卡 -->
      <div class="topic-hero">
        <h1 id="page-title">{topic.name}</h1>
        <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap;">
          <span class={`topic-tag ${topic.type}`}>{topic.type === 'longterm' ? '长期板块' : '短期板块'}</span>
          {!topic.active && <span class="topic-tag archived">已归档</span>}
        </div>

        {topic.type === 'shortterm' && (
          <p style="color: #888; font-size: 0.85rem; margin-top: 0.5rem;">
            时间范围：{topic.startDate} ~ {topic.endDate}
          </p>
        )}
      </div>

      {currentTopicSummary && (
        <section class="topic-section topic-inline-brief">
          <div class="topic-section-header">
            <h2>今日看点</h2>
          </div>
          <div class="topic-daily-brief summary-collapsible">
            <div class={`summary-card-content ${shouldCollapseSummary(currentTopicSummary) ? 'is-collapsed' : ''}`}>
              <p>{currentTopicSummary.summary}</p>
              {currentTopicSummary.highlights.length > 0 && (
                <ul>
                  {currentTopicSummary.highlights.map(highlight => <li>{highlight}</li>)}
                </ul>
              )}
            </div>
            {shouldCollapseSummary(currentTopicSummary) && (
              <button type="button" class="summary-card-toggle summary-card-toggle--inline" aria-expanded="false">
                展开全部
              </button>
            )}
          </div>
        </section>
      )}

      <!-- ===== 概览视图 ===== -->
      <div id="overview-view">
        <!-- TOP10 -->
        <section id="top10" class="topic-section">
          <div class="topic-section-header">
            <h2>🔥 热门 TOP10</h2>
          </div>
          {top10.length > 0 ? (
            <div class="topic-list">
              {top10.map((item, idx) => (
                <article class="topic-item">
                  <span class="item-rank">{idx + 1}</span>
                  <div class="item-body">
                    <h3 class="item-title">
                      <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                      <span class="item-source">{item.source}</span>
                    </h3>
                    <p class="item-summary">{getItemSummary(item)}</p>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="topic-empty">暂无热门资讯</div>
          )}
        </section>

        {hasSubtopics ? (
          orderedSubtopics.map(subtopic => {
            const { items, allItems } = getDisplayedSubtopicItems(subtopic.id, 5);
            const subtopicSummary = getSubtopicSummary(subtopic.id);
            const todayCount = allItems.length;
            return (
              <section id={`subtopic-${subtopic.id}`} class="topic-section subtopic-section" data-subtopic={subtopic.id}>
                <div class="topic-section-header">
                  <h2>{subtopic.name}</h2>
                  <a href={`/daily-news/topic/${topic.id}/?subtopic=${subtopic.id}&date=${currentDate}`} class="source-home-link">
                    查看全部 {todayCount} 条 →
                  </a>
                </div>
                {subtopicSummary && (
                  <div class="topic-daily-brief topic-inline-brief summary-collapsible">
                    <div class={`summary-card-content ${shouldCollapseSummary(subtopicSummary) ? 'is-collapsed' : ''}`}>
                      <p>{subtopicSummary.summary}</p>
                      {subtopicSummary.highlights.length > 0 && (
                        <ul>
                          {subtopicSummary.highlights.map(highlight => <li>{highlight}</li>)}
                        </ul>
                      )}
                    </div>
                    {shouldCollapseSummary(subtopicSummary) && (
                      <button type="button" class="summary-card-toggle summary-card-toggle--inline" aria-expanded="false">
                        展开全部
                      </button>
                    )}
                  </div>
                )}
                {items.length > 0 ? (
                  <div class="topic-list">
                    {items.map(item => (
                      <article class="topic-item">
                        <div class="item-body" style="margin-left: 0;">
                          <h3 class="item-title">
                            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                            <span class="item-source">{item.source}</span>
                          </h3>
                          <p class="item-summary">{getItemSummary(item)}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                ) : (
                  <div class="topic-empty">当日暂无 {subtopic.name} 资讯</div>
                )}
              </section>
            );
          })
        ) : (
          sortedSources.map(src => {
            const { items, allItems, fallbackCount } = getDisplayedItems(src.id, 5);
            const todayCount = allItems.length;
            return (
              <section id={`src-${src.id}`} class="topic-section source-section" data-source={src.id}>
                <div class="topic-section-header">
                  <h2>
                    {src.name}
                    {fallbackCount > 0 && (
                      <span style="font-size: 0.75rem; color: #888; font-weight: 400; margin-left: 0.5rem;">
                        含 {fallbackCount} 条昨日补充
                      </span>
                    )}
                  </h2>
                  <a href={`/daily-news/topic/${topic.id}/?source=${src.id}&date=${currentDate}`} class="source-home-link">
                    查看全部 {todayCount} 条 →
                  </a>
                </div>
                {items.length > 0 ? (
                  <div class="topic-list">
                    {items.map(item => (
                      <article class="topic-item">
                        <div class="item-body" style="margin-left: 0;">
                          <h3 class="item-title">
                            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                          </h3>
                          <p class="item-summary">{getItemSummary(item)}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                ) : (
                  <div class="topic-empty">当日暂无 {src.name} 资讯</div>
                )}
                <div style="margin-top: 0.75rem; text-align: right;">
                  <a href={src.url} target="_blank" rel="noopener noreferrer" style="color: #888; font-size: 0.85rem;">
                    访问 {src.name} 官网 ↗
                  </a>
                </div>
              </section>
            );
          })
        )}
      </div>

      <!-- ===== 分组详情视图容器（动态填充） ===== -->
      <div id="group-detail-view" style="display: none;">
        <div id="group-detail-content"></div>
      </div>

      <!-- 预渲染所有分组详情（隐藏，供 JS 复制） -->
      <div style="display: none;" id="group-detail-templates">
        {hasSubtopics ? (
          subtopicDetails.map(subtopic => (
            <div data-group={subtopic.id} class="group-detail-template">
              <section class="topic-section">
                <div class="topic-section-header">
                  <h2>{subtopic.name}</h2>
                </div>
                {subtopic.summary && (
                  <div class="topic-daily-brief topic-inline-brief summary-collapsible">
                    <div class={`summary-card-content ${shouldCollapseSummary(subtopic.summary) ? 'is-collapsed' : ''}`}>
                      <p>{subtopic.summary.summary}</p>
                      {subtopic.summary.highlights.length > 0 && (
                        <ul>
                          {subtopic.summary.highlights.map(highlight => <li>{highlight}</li>)}
                        </ul>
                      )}
                    </div>
                    {shouldCollapseSummary(subtopic.summary) && (
                      <button type="button" class="summary-card-toggle summary-card-toggle--inline" aria-expanded="false">
                        展开全部
                      </button>
                    )}
                  </div>
                )}
                {subtopic.todayItems.length > 0 ? (
                  <div class="topic-list">
                    {subtopic.todayItems.map(item => (
                      <article class="topic-item">
                        <div class="item-body" style="margin-left: 0;">
                          <h3 class="item-title">
                            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                            <span class="item-source">{item.source}</span>
                          </h3>
                          <p class="item-summary">{getItemSummary(item)}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                ) : (
                  <div class="topic-empty">当日暂无 {subtopic.name} 资讯</div>
                )}
              </section>
            </div>
          ))
        ) : (
          sourceDetails.map(src => (
            <div data-group={src.id} class="group-detail-template">
              <section class="topic-section">
                <div class="topic-section-header">
                  <h2>
                    {src.name}
                    {src.fallbackItems.length > 0 && (
                      <span style="font-size: 0.75rem; color: #888; font-weight: 400; margin-left: 0.5rem;">
                        含 {src.fallbackItems.length} 条昨日补充
                      </span>
                    )}
                  </h2>
                </div>
                {[...src.todayItems, ...src.fallbackItems].length > 0 ? (
                  <div class="topic-list">
                    {[...src.todayItems, ...src.fallbackItems].map((item, idx) => (
                      <article class="topic-item">
                        <div class="item-body" style="margin-left: 0;">
                          <h3 class="item-title">
                            <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                            {idx >= src.todayItems.length && (
                              <span class="item-source" style="background: #fef3c7; color: #92400e;">昨日</span>
                            )}
                          </h3>
                          <p class="item-summary">{getItemSummary(item)}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                ) : (
                  <div class="topic-empty">当日暂无 {src.name} 资讯</div>
                )}
                <div style="margin-top: 1.5rem; text-align: center;">
                  <a href={src.url} target="_blank" rel="noopener noreferrer" class="btn" style="background: #fff; color: #2563eb; border: 1px solid #2563eb;">
                    访问 {src.name} 官网 ↗
                  </a>
                </div>
              </section>
            </div>
          ))
        )}
      </div>
    </main>

    <aside class="summary-sidebar" aria-label={`${topic.name} 当日总结`}>
      <div class="summary-sidebar-inner">
        <article class="summary-card active" data-summary-topic={topic.id}>
          <div class="summary-card-header">
            <span class="summary-card-icon">📝</span>
            <h2>{topic.name}总结</h2>
          </div>
          {currentTopicSummary ? (
            <>
              <div class={`summary-card-content ${shouldCollapseSummary(currentTopicSummary) ? 'is-collapsed' : ''}`}>
                <p>{currentTopicSummary.summary}</p>
                {currentTopicSummary.highlights.length > 0 && (
                  <ul>
                    {currentTopicSummary.highlights.map(highlight => <li>{highlight}</li>)}
                  </ul>
                )}
              </div>
              {shouldCollapseSummary(currentTopicSummary) && (
                <button type="button" class="summary-card-toggle" aria-expanded="false">
                  展开全部
                </button>
              )}
            </>
          ) : (
            <p class="summary-empty">当日暂无板块总结</p>
          )}
        </article>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  (function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const layout = document.querySelector('.daily-news-layout--topic');
    const groupParam = layout?.getAttribute('data-group-param') || 'source';
    const overviewNavTitle = layout?.getAttribute('data-overview-nav-title') || '📖 来源导航';

    document.querySelectorAll('.sidebar-link[href^="#"]').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
        }
      });
    });

    function getGroupFromUrl() {
      const url = new URL(window.location.href);
      return url.searchParams.get(groupParam);
    }

    function updateDateNavLinks(group: string | null) {
      document.querySelectorAll('.date-nav').forEach(el => {
        const date = el.getAttribute('data-date');
        const base = `/daily-news/topic/${location.pathname.split('/')[3]}/`;
        if (group) {
          el.setAttribute('href', `${base}?${groupParam}=${encodeURIComponent(group)}&date=${date}`);
        } else {
          el.setAttribute('href', `${base}?date=${date}`);
        }
      });
    }

    function getCurrentDate() {
      const url = new URL(window.location.href);
      return url.searchParams.get('date') || document.querySelector('.date-nav.active')?.getAttribute('data-date') || '';
    }

    function getOverviewUrl() {
      const base = `/daily-news/topic/${location.pathname.split('/')[3]}/`;
      const date = getCurrentDate();
      return date ? `${base}?date=${date}` : base;
    }

    function findGroupLink(group: string) {
      return Array.from(document.querySelectorAll('.nav-group')).find(link =>
        (link as HTMLElement).dataset.group === group
      );
    }

    function findGroupTemplate(group: string) {
      return Array.from(document.querySelectorAll('#group-detail-templates .group-detail-template')).find(template =>
        (template as HTMLElement).dataset.group === group
      );
    }

    function switchView() {
      const group = getGroupFromUrl();
      const overview = document.getElementById('overview-view');
      const detailView = document.getElementById('group-detail-view');
      const detailContent = document.getElementById('group-detail-content');
      const backLink = document.querySelector('.back-link');
      const backOverview = document.getElementById('back-to-overview');
      const pageTitle = document.getElementById('page-title');
      const sidebarTitle = document.getElementById('sidebar-title');
      const navOverview = document.getElementById('nav-overview');

      updateDateNavLinks(group);
      if (navOverview) {
        navOverview.setAttribute('href', group ? getOverviewUrl() : '#top10');
      }

      document.querySelectorAll('.sidebar-link').forEach(link => link.classList.remove('active'));
      if (group) {
        const activeLink = findGroupLink(group);
        activeLink?.classList.add('active');
      } else {
        if (navOverview) navOverview.classList.add('active');
      }

      if (group && detailContent && detailView) {
        if (overview) overview.style.display = 'none';
        detailView.style.display = 'block';

        const template = findGroupTemplate(group);
        if (template) {
          detailContent.innerHTML = template.innerHTML;
        } else {
          detailContent.innerHTML = `<div class="topic-empty">未找到该${groupParam === 'subtopic' ? '子主题' : '来源'}</div>`;
        }

        const groupName = findGroupLink(group)?.querySelector('.sidebar-name')?.textContent || group;
        if (pageTitle) pageTitle.textContent = `${groupName} — ${pageTitle.getAttribute('data-original') || '详情'}`;
        if (sidebarTitle) sidebarTitle.textContent = `📖 ${groupName}`;

        if (backLink) (backLink as HTMLElement).style.display = 'none';
        if (backOverview) backOverview.style.display = 'inline';
      } else {
        if (overview) overview.style.display = 'block';
        if (detailView) detailView.style.display = 'none';

        if (pageTitle) pageTitle.textContent = pageTitle.getAttribute('data-original') || pageTitle.textContent.split('—')[0]?.trim() || '详情';
        if (sidebarTitle) sidebarTitle.textContent = overviewNavTitle;

        if (backLink) (backLink as HTMLElement).style.display = 'inline';
        if (backOverview) backOverview.style.display = 'none';
      }
    }

    const pageTitle = document.getElementById('page-title');
    if (pageTitle && !pageTitle.getAttribute('data-original')) {
      pageTitle.setAttribute('data-original', pageTitle.textContent);
    }

    switchView();

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const button = target?.closest('.summary-card-toggle');
      if (!button) return;

      const container = button.closest('.summary-collapsible, .summary-card');
      const content = container?.querySelector('.summary-card-content');
      if (!content) return;

      const isCollapsed = content.classList.toggle('is-collapsed');
      button.textContent = isCollapsed ? '展开全部' : '收起';
      button.setAttribute('aria-expanded', String(!isCollapsed));
    });

    window.addEventListener('popstate', switchView);
  })();
</script>

<style>
  .topic-section {
    scroll-margin-top: 80px;
  }
</style>
