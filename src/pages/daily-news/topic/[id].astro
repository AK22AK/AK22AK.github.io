---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Calendar from '../../../components/Calendar.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import {
  buildSourceMeta,
  formatDateLabel,
  getClusterHeatFlames,
  getDisplayQualityReasons,
  getItemSubtopic,
  getSourceName,
  getSubtopicName,
  getSubtopicIcon,
  getTopicClusters,
  getTopicIcon,
  getTopicReport,
  getWeekdayLabel,
  groupItemsBySource,
  groupItemsBySubtopic,
  normalizeDailyBrief,
  normalizeStoryClusters,
  readSourcesIndex,
  resolveClusterRefs,
  type DailyNewsData,
  type TopicConfig,
} from '../../../lib/dailyNews';

export async function getStaticPaths() {
  const topicsPath = path.resolve('./src/data/daily-news-topics.json');
  const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
  const topics = topicsConfig.topics;
  return topics.map((topic: TopicConfig) => ({
    params: { id: topic.id },
    props: { topic },
  }));
}

const { topic } = Astro.props as { topic: TopicConfig };

const topicsPath = path.resolve('./src/data/daily-news-topics.json');
const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
const allTopics = topicsConfig.topics as TopicConfig[];

const newsData = await getCollection('daily-news');
const dateEntries = newsData.filter(entry => entry.id !== 'topics');
dateEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = new URL(Astro.request.url);
const selectedDate = url.searchParams.get('date');
const availableDates = dateEntries.map(e => e.data.date);
const currentDate = selectedDate && availableDates.includes(selectedDate)
  ? selectedDate
  : (availableDates[0] || '');
const currentEntry = dateEntries.find(e => e.data.date === currentDate);
const currentData = currentEntry?.data as DailyNewsData | undefined;
const allItems = currentData?.items || [];
const currentItems = allItems.filter(item => item.topic === topic.id);
const sourceMeta = buildSourceMeta(allTopics);
const topicSourceMeta = buildSourceMeta([topic]);
const sourcesIndex = readSourcesIndex();
const storyClusters = getTopicClusters(normalizeStoryClusters(currentData, allTopics), topic.id);
const topicReport = getTopicReport(currentData, topic.id);
const dailyBrief = normalizeDailyBrief(currentData, allTopics);
const topicSummary = currentData?.topic_summaries?.find(summary => summary.topic === topic.id);
const fallbackTopicReport = !topicReport && topic.type === 'shortterm' && topicSummary
  ? {
      title: topicSummary.highlights?.[0] || topic.name,
      subtitle: '旧数据摘要',
      summary: topicSummary.summary,
      sections: topicSummary.highlights?.length
        ? [{ type: 'list' as const, title: '今日要点', items: topicSummary.highlights }]
        : [],
    }
  : undefined;
const visibleTopicReport = topicReport || fallbackTopicReport;
const currentWeekday = getWeekdayLabel(currentDate);
const rawSubtopicGroups = groupItemsBySubtopic(currentItems, topic);
const rawSubtopicMap = new Map(rawSubtopicGroups.map(group => [group.id, group]));
const clusterSubtopicCounts = new Map<string, number>();
for (const cluster of storyClusters) {
  if (!cluster.subtopic) continue;
  clusterSubtopicCounts.set(cluster.subtopic, (clusterSubtopicCounts.get(cluster.subtopic) || 0) + 1);
}
const configuredSubtopicIds = topic.subtopics?.map(subtopic => subtopic.id) || [];
const discoveredSubtopicIds = Array.from(new Set([
  ...configuredSubtopicIds,
  ...Array.from(rawSubtopicMap.keys()),
  ...Array.from(clusterSubtopicCounts.keys()),
]));
const subtopicGroups = discoveredSubtopicIds
  .map(id => ({
    id,
    name: getSubtopicName(topic, id),
    items: rawSubtopicMap.get(id)?.items || [],
    clusterCount: clusterSubtopicCounts.get(id) || 0,
    configured: configuredSubtopicIds.includes(id),
  }))
  .filter(group => group.configured || group.clusterCount > 0 || group.items.length > 0)
  .filter(group => group.id !== 'uncategorized');
const subtopicSections = subtopicGroups
  .map(group => ({
    ...group,
    clusters: storyClusters.filter(cluster => cluster.subtopic === group.id),
  }))
  .filter(group => group.clusters.length > 0 || group.items.length > 0);
const prioritySubtopicId = 'morning-brief';
const prioritySubtopicGroups = subtopicGroups.filter(group => group.id === prioritySubtopicId);
const regularSubtopicGroups = subtopicGroups.filter(group => group.id !== prioritySubtopicId);
const prioritySubtopicSections = subtopicSections.filter(group => group.id === prioritySubtopicId);
const regularSubtopicSections = subtopicSections.filter(group => group.id !== prioritySubtopicId);
const sourceGroups = groupItemsBySource(currentItems, sourcesIndex, currentDate, topicSourceMeta);
const sourceCount = new Set(currentItems.map(item => item.source)).size;
---

<BaseLayout title={`${topic.name} - 每日资讯 - AK22AK`} description={`AK22AK 关注的 ${topic.name} 资讯详情`} variant="news">
  <div class="daily-news-layout daily-news-layout--brief daily-news-layout--topic">
    <aside class="sidebar">
      <div class="sidebar-inner">
        <div class="sidebar-backlinks">
          <a href={`/daily-news/?date=${currentDate}`} class="back-link">返回每日简报</a>
        </div>
        <h3 class="sidebar-title">{topic.name}</h3>
        <nav class="sidebar-nav" aria-label={`${topic.name} 导航`}>
          <a href="#topic-brief" class="sidebar-link active" data-section-link="true">
            <span class="sidebar-icon">{getTopicIcon(topic.id)}</span>
            <span class="sidebar-name">板块总览</span>
          </a>
          {prioritySubtopicGroups.map(group => {
            const hasSection = group.clusterCount > 0 || group.items.length > 0;
            return hasSection ? (
              <a
                href={`#subtopic-${group.id}`}
                class="sidebar-link"
                data-section-link="true"
              >
                <span class="sidebar-icon">{getSubtopicIcon(group.id)}</span>
                <span class="sidebar-name">{group.name}</span>
                <span class="sidebar-count">{group.clusterCount || group.items.length}</span>
              </a>
            ) : (
              <span class="sidebar-link sidebar-link--disabled muted" aria-disabled="true">
                <span class="sidebar-icon">{getSubtopicIcon(group.id)}</span>
                <span class="sidebar-name">{group.name}</span>
                <span class="sidebar-count">0</span>
              </span>
            );
          })}
          <a href="#today-hot" class="sidebar-link" data-section-link="true">
            <span class="sidebar-icon">🔥</span>
            <span class="sidebar-name">今日热门</span>
            <span class="sidebar-count">{visibleTopicReport ? 1 : storyClusters.length}</span>
          </a>
          {regularSubtopicGroups.map(group => {
            const hasSection = group.clusterCount > 0 || group.items.length > 0;
            return hasSection ? (
              <a
                href={`#subtopic-${group.id}`}
                class="sidebar-link"
                data-section-link="true"
              >
                <span class="sidebar-icon">{getSubtopicIcon(group.id)}</span>
                <span class="sidebar-name">{group.name}</span>
                <span class="sidebar-count">{group.clusterCount || group.items.length}</span>
              </a>
            ) : (
              <span class="sidebar-link sidebar-link--disabled muted" aria-disabled="true">
                <span class="sidebar-icon">{getSubtopicIcon(group.id)}</span>
                <span class="sidebar-name">{group.name}</span>
                <span class="sidebar-count">0</span>
              </span>
            );
          })}
        </nav>
        <Calendar dates={availableDates} currentDate={currentDate} baseUrl={`/daily-news/topic/${topic.id}/`} />
        <div class="sidebar-footer">
          <a href="#sources" class="sidebar-link muted" data-section-link="true">
            来源
            <span class="sidebar-count">{sourceCount}</span>
          </a>
        </div>
      </div>
    </aside>

    <main class="daily-main">
      <header id="topic-brief" class="news-brief-hero news-brief-hero--topic">
        <div class="brief-kicker">
          <span>{formatDateLabel(currentDate)}</span>
          {currentWeekday && <span>{currentWeekday}</span>}
          <span>{currentItems.length} 条资讯</span>
          <span>{sourceCount} 个来源</span>
        </div>
        <h1>{topic.name}</h1>
        <p>{topicSummary?.summary || topic.description || dailyBrief.summary}</p>
      </header>

      {prioritySubtopicSections.length > 0 && (
        <div class="subtopic-section-list subtopic-section-list--priority">
          {prioritySubtopicSections.map(group => (
            <section id={`subtopic-${group.id}`} class="topic-section subtopic-section">
              <div class="topic-section-header">
                <h2>
                  <span class="topic-section-icon">{getSubtopicIcon(group.id)}</span>
                  {group.name}
                </h2>
              </div>
              <div class="topic-overview-meta">
                <span>{group.items.length} 条原文</span>
                {group.clusters.length > 0 && <span>{group.clusters.length} 条线索</span>}
              </div>
              {group.clusters.length > 0 ? (
                <div class="story-cluster-list story-cluster-list--compact">
                  {group.clusters.map(cluster => {
                    const refItems = resolveClusterRefs(allItems, cluster, 5);
                    const qualityReasons = getDisplayQualityReasons(cluster);
                    return (
                      <article class={`story-cluster-row story-cluster-card--${cluster.importance}`}>
                        <div class="cluster-meta">
                          <span>{cluster.importance === 'lead' ? '主线' : cluster.importance === 'major' ? '重点' : '补充'}</span>
                          <span class="heat-chip" title="今日热度">{getClusterHeatFlames(cluster)}</span>
                        </div>
                        <h3>
                          <a href={`#cluster-${cluster.id}`}>{cluster.title}</a>
                        </h3>
                        <p>{cluster.summary}</p>
                        {qualityReasons.length > 0 && (
                          <div class="quality-chip-row">
                            {qualityReasons.map(reason => <span>{reason}</span>)}
                          </div>
                        )}
                        {refItems.length > 0 && (
                          <details class="cluster-ref-list" open>
                            <summary>查看 {refItems.length} 条引用</summary>
                            {refItems.map(item => (
                              <a href={item.url} target="_blank" rel="noopener noreferrer">
                                <span>{getSourceName(item.source, sourceMeta)}</span>
                                <strong>{item.title}</strong>
                              </a>
                            ))}
                          </details>
                        )}
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div class="topic-list topic-list--compact">
                  {group.items.map(item => (
                    <article class="topic-item">
                      <div class="item-body">
                        <h3 class="item-title">
                          <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                          <span class="item-source">{getSourceName(item.source, sourceMeta)}</span>
                        </h3>
                        <p class="item-summary">{item.ai_summary || item.summary}</p>
                      </div>
                    </article>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      )}

      <section id="today-hot" class="story-cluster-section">
        <div class="topic-section-header">
          <h2>今日热门</h2>
        </div>

        {visibleTopicReport ? (
          <article class="topic-report-detail">
            <div class="cluster-meta">
              <span>专题晨报</span>
              {!topicReport && <span>旧数据摘要</span>}
              {visibleTopicReport.generated_at && <span>更新 {new Date(visibleTopicReport.generated_at).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}</span>}
            </div>
            <h3>{visibleTopicReport.title}</h3>
            {visibleTopicReport.subtitle && <p class="report-subtitle">{visibleTopicReport.subtitle}</p>}
            {visibleTopicReport.summary && <p>{visibleTopicReport.summary}</p>}
            <div class="report-section-list">
              {visibleTopicReport.sections.map(section => (
                <section class={`report-section report-section--${section.type}`}>
                  <h4>{section.title}</h4>
                  {section.content && <p>{section.content}</p>}
                  {section.rows?.length ? (
                    <div class="report-table">
                      {section.rows.map(row => (
                        <div class="report-row">
                          {Object.entries(row).map(([key, value]) => (
                            <span data-label={key}>{value}</span>
                          ))}
                        </div>
                      ))}
                    </div>
                  ) : null}
                  {section.items?.length ? (
                    <ul class="report-list">
                      {section.items.map(item => <li>{item}</li>)}
                    </ul>
                  ) : null}
                </section>
              ))}
            </div>
            {visibleTopicReport.refs?.length ? (
              <details class="cluster-ref-list" open>
                <summary>查看 {visibleTopicReport.refs.length} 条引用</summary>
                {resolveClusterRefs(allItems, { refs: visibleTopicReport.refs }, 5).map(item => (
                  <a href={item.url} target="_blank" rel="noopener noreferrer">
                    <span>{getSourceName(item.source, sourceMeta)}</span>
                    <strong>{item.title}</strong>
                  </a>
                ))}
              </details>
            ) : null}
          </article>
        ) : storyClusters.length > 0 ? (
          <div class="story-cluster-list">
            {storyClusters.map(cluster => {
              const refItems = resolveClusterRefs(allItems, cluster, 5);
              const qualityReasons = getDisplayQualityReasons(cluster);
              return (
                <article
                  id={`cluster-${cluster.id}`}
                  class={`story-cluster-card story-cluster-card--${cluster.importance}`}
                >
                  <div class="cluster-meta">
                    {cluster.subtopic && <span>{getSubtopicIcon(cluster.subtopic)} {getSubtopicName(topic, cluster.subtopic)}</span>}
                    <span>{cluster.importance === 'lead' ? '主线' : cluster.importance === 'major' ? '重点' : '补充'}</span>
                    <span class="heat-chip" title="今日热度">{getClusterHeatFlames(cluster)}</span>
                  </div>
                  <h3>{cluster.title}</h3>
                  <p>{cluster.summary}</p>
                  {cluster.why_it_matters && <p class="cluster-why">{cluster.why_it_matters}</p>}
                  {qualityReasons.length > 0 && (
                    <div class="quality-chip-row">
                      {qualityReasons.map(reason => <span>{reason}</span>)}
                    </div>
                  )}
                  {refItems.length > 0 && (
                    <details class="cluster-ref-list" open>
                      <summary>查看 {refItems.length} 条引用</summary>
                      {refItems.map(item => (
                        <a href={item.url} target="_blank" rel="noopener noreferrer">
                          <span>{getSourceName(item.source, sourceMeta)}</span>
                          <strong>{item.title}</strong>
                        </a>
                      ))}
                    </details>
                  )}
                </article>
              );
            })}
          </div>
        ) : (
          <div class="topic-empty">当前暂无今日热门，下面可在来源透明度里查看原文。</div>
        )}
      </section>

      {regularSubtopicSections.length > 0 && (
        <div class="subtopic-section-list">
          {regularSubtopicSections.map(group => (
            <section id={`subtopic-${group.id}`} class="topic-section subtopic-section">
              <div class="topic-section-header">
                <h2>
                  <span class="topic-section-icon">{getSubtopicIcon(group.id)}</span>
                  {group.name}
                </h2>
              </div>
              <div class="topic-overview-meta">
                <span>{group.items.length} 条原文</span>
                {group.clusters.length > 0 && <span>{group.clusters.length} 条线索</span>}
              </div>
              {group.clusters.length > 0 ? (
                <div class="story-cluster-list story-cluster-list--compact">
                  {group.clusters.map(cluster => {
                    const refItems = resolveClusterRefs(allItems, cluster, 5);
                    const qualityReasons = getDisplayQualityReasons(cluster);
                    return (
                      <article class={`story-cluster-row story-cluster-card--${cluster.importance}`}>
                        <div class="cluster-meta">
                          <span>{cluster.importance === 'lead' ? '主线' : cluster.importance === 'major' ? '重点' : '补充'}</span>
                          <span class="heat-chip" title="今日热度">{getClusterHeatFlames(cluster)}</span>
                        </div>
                        <h3>
                          <a href={`#cluster-${cluster.id}`}>{cluster.title}</a>
                        </h3>
                        <p>{cluster.summary}</p>
                        {qualityReasons.length > 0 && (
                          <div class="quality-chip-row">
                            {qualityReasons.map(reason => <span>{reason}</span>)}
                          </div>
                        )}
                        {refItems.length > 0 && (
                          <details class="cluster-ref-list" open>
                            <summary>查看 {refItems.length} 条引用</summary>
                            {refItems.map(item => (
                              <a href={item.url} target="_blank" rel="noopener noreferrer">
                                <span>{getSourceName(item.source, sourceMeta)}</span>
                                <strong>{item.title}</strong>
                              </a>
                            ))}
                          </details>
                        )}
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div class="topic-list topic-list--compact">
                  {group.items.map(item => (
                    <article class="topic-item">
                      <div class="item-body">
                        <h3 class="item-title">
                          <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                          <span class="item-source">{getSourceName(item.source, sourceMeta)}</span>
                        </h3>
                        <p class="item-summary">{item.ai_summary || item.summary}</p>
                      </div>
                    </article>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      )}

      <section id="sources" class="topic-section">
        <div class="topic-section-header">
          <h2>来源透明度</h2>
          <span class="source-audit-total">{currentItems.length} 条原文</span>
          <a href={`/daily-news/sources/?date=${currentDate}`} class="topic-more">查看全部来源 →</a>
        </div>
        {sourceGroups.length > 0 ? (
          <div class="source-audit-groups source-audit-groups--compact source-audit-groups--details">
            {sourceGroups.map(group => (
              <details class="source-audit-group" data-source-group>
                <summary class="source-audit-header">
                  <div>
                    <h3>{group.name}</h3>
                    <p>{group.id}</p>
                  </div>
                  <span data-source-group-count>{group.count} 条</span>
                </summary>
                <ol class="source-audit-list">
                  {group.items.map(item => (
                    <li>
                      <a href={item.url} target="_blank" rel="noopener noreferrer">
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ol>
              </details>
            ))}
          </div>
        ) : (
          <div class="topic-empty">暂无来源数据。</div>
        )}
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sidebarLinks = document.querySelectorAll('.sidebar-link[data-section-link="true"]');
  const sections = document.querySelectorAll('#topic-brief, .topic-section[id], .story-cluster-section[id]');

  sidebarLinks.forEach(link => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const target = document.querySelector(href);
      if (!target) return;
      event.preventDefault();
      window.history.pushState(null, '', href);
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
    });
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      sidebarLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (!href) return;
        const url = new URL(href, window.location.href);
        if (url.pathname !== window.location.pathname || url.search !== window.location.search) return;
        link.classList.toggle('active', url.hash === `#${entry.target.id}`);
      });
    });
  }, { rootMargin: '-20% 0px -65% 0px' });

  sections.forEach(section => observer.observe(section));
</script>

<style>
  #topic-brief,
  .daily-news-layout--topic .topic-section[id],
  .daily-news-layout--topic .story-cluster-section[id],
  .story-cluster-card[id] {
    scroll-margin-top: 96px;
  }

  @media (max-width: 768px) {
    #topic-brief,
    .daily-news-layout--topic .topic-section[id],
    .daily-news-layout--topic .story-cluster-section[id],
    .story-cluster-card[id] {
      scroll-margin-top: 72px;
    }
  }
</style>
