---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const topicsPath = path.resolve('./src/data/daily-news-topics.json');
const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
const topics = topicsConfig.topics as Array<{
  id: string; name: string; type: string; description: string;
  active: boolean; startDate?: string; endDate?: string;
}>;

const newsData = await getCollection('daily-news');
const dateEntries = newsData.filter(entry => entry.id !== 'topics');
dateEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = new URL(Astro.request.url);
const selectedDate = url.searchParams.get('date');
const availableDates = dateEntries.map(e => e.data.date);
const currentDate = selectedDate && availableDates.includes(selectedDate)
  ? selectedDate
  : (availableDates[0] || '');
const currentEntry = dateEntries.find(e => e.data.date === currentDate);
const currentItems = currentEntry?.data.items || [];

const activeTopics = topics.filter(t => t.active);
const archivedTopics = topics.filter(t => t.type === 'shortterm' && !t.active);

const weekdayNames = ['周日','周一','周二','周三','周四','周五','周六'];
const currentWeekday = currentDate ? weekdayNames[new Date(currentDate).getDay()] : '';

function getTopicIcon(id: string) {
  const map: Record<string, string> = {
    tech: '🔥',
    game: '🎮',
    snooker: '🎱',
  };
  return map[id] || '📰';
}
---

<BaseLayout title="每日新闻 - AK22AK" description="AK22AK 关注的每日资讯聚合">
  <div class="daily-news-layout">
    <!-- 侧边栏导航 -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <h3 class="sidebar-title">📖 模块导航</h3>
        <nav class="sidebar-nav">
          {activeTopics.map(topic => {
            const items = currentItems.filter(item => item.topic === topic.id);
            return (
              <a href={`#${topic.id}`} class="sidebar-link">
                <span class="sidebar-icon">{getTopicIcon(topic.id)}</span>
                <span class="sidebar-name">{topic.name}</span>
                {items.length > 0 && <span class="sidebar-count">{items.length}</span>}
              </a>
            );
          })}
        </nav>
        <div class="sidebar-footer">
          <a href="/daily-news/archive/" class="sidebar-link muted">
            <span class="sidebar-icon">📂</span>
            <span class="sidebar-name">全部归档</span>
          </a>
        </div>
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="daily-main">
      <!-- 日期头部 -->
      <header class="date-header">
        <div class="date-title">
          <span class="date-icon">📰</span>
          <h1>每日早报 {currentDate.replace(/-/g, '.')}</h1>
        </div>
        <span class="date-weekday">{currentWeekday}</span>
        <p class="date-desc">
          今日精选 {currentItems.length} 条资讯，为你摘选 {activeTopics.map(t => t.name).join('、')} 动态。
        </p>

        <div class="date-list">
          {availableDates.map(date => (
            <a
              href={`/daily-news/?date=${date}`}
              class={`date-pill ${date === currentDate ? 'active' : ''}`}
            >
              {date.slice(5)}
            </a>
          ))}
        </div>
      </header>

      <!-- 板块内容 -->
      {activeTopics.map(topic => {
        const items = currentItems.filter(item => item.topic === topic.id);
        return (
          <section id={topic.id} class="topic-section">
            <div class="topic-section-header">
              <h2>
                <span class="topic-section-icon">{getTopicIcon(topic.id)}</span>
                {topic.name}
              </h2>
              <a href={`/daily-news/topic/${topic.id}/`} class="topic-more">查看全部 →</a>
            </div>

            {items.length > 0 ? (
              <div class="topic-list">
                {items.map(item => (
                  <article class="topic-item">
                    <h3 class="item-title">
                      <a href={item.url} target="_blank">{item.title}</a>
                    </h3>
                    <p class="item-summary">{item.summary}</p>
                    <span class="item-source">{item.source}</span>
                  </article>
                ))}
              </div>
            ) : (
              <div class="topic-empty">当日暂无 {topic.name} 资讯</div>
            )}
          </section>
        );
      })}

      {archivedTopics.length > 0 && (
        <section class="topic-section">
          <h2>🗄 已归档板块</h2>
          <div class="archived-grid">
            {archivedTopics.map(topic => (
              <a href={`/daily-news/topic/${topic.id}/`} class="card archived-card">
                <span class="archived-name">{topic.name}</span>
                <span class="archived-tag">已结束</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  // 简单的锚点平滑滚动 + 侧边栏高亮
  document.querySelectorAll('.sidebar-link[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // 滚动时高亮当前板块
  const sections = document.querySelectorAll('.topic-section[id]');
  const sidebarLinks = document.querySelectorAll('.sidebar-link[href^="#"]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        sidebarLinks.forEach(link => link.classList.remove('active'));
        const activeLink = document.querySelector(`.sidebar-link[href="#${entry.target.id}"]`);
        if (activeLink) activeLink.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });

  sections.forEach(section => observer.observe(section));
</script>
