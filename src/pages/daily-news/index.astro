---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Calendar from '../../components/Calendar.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const topicsPath = path.resolve('./src/data/daily-news-topics.json');
const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
const topics = topicsConfig.topics as Array<{
  id: string; name: string; type: string; description: string;
  active: boolean; sources: Array<{id: string; name: string; url: string}>;
}>;

const newsData = await getCollection('daily-news');
const dateEntries = newsData.filter(entry => entry.id !== 'topics');
dateEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = new URL(Astro.request.url);
const selectedDate = url.searchParams.get('date');
const availableDates = dateEntries.map(e => e.data.date);
const currentDate = selectedDate && availableDates.includes(selectedDate)
  ? selectedDate
  : (availableDates[0] || '');
const currentEntry = dateEntries.find(e => e.data.date === currentDate);
const currentItems = currentEntry?.data.items || [];
const currentTopicSummaries = currentEntry?.data.topic_summaries || [];

const activeTopics = topics.filter(t => t.active);
const archivedTopics = topics.filter(t => t.type === 'shortterm' && !t.active);

const weekdayNames = ['周日','周一','周二','周三','周四','周五','周六'];
const currentWeekday = currentDate ? weekdayNames[new Date(currentDate).getDay()] : '';

function getTopicIcon(id: string) {
  const map: Record<string, string> = { tech: '🔥', game: '🎮', snooker: '🎱' };
  return map[id] || '📰';
}

// ===== 权重排序系统 =====
const BRAND_KEYWORDS = [
  '苹果', 'iPhone', 'iPad', 'Mac', '小米', '华为', '三星', 'OPPO', 'vivo',
  '谷歌', 'Pixel', '特斯拉', '比亚迪', 'OpenAI', 'ChatGPT', 'Claude',
  '英伟达', 'NVIDIA', 'AMD', '英特尔', '微软', 'Meta', 'Steam',
  '腾讯', '阿里', '字节', '百度', '网易', 'B站', '哔哩哔哩',
  '微信', '抖音', '淘宝', '京东', '拼多多',
  '马云', '马化腾', '雷军', '马斯克',
  '宁德时代', '大疆',
];

function hasBrandKeyword(title: string): boolean {
  return BRAND_KEYWORDS.some(kw => title.includes(kw));
}

function hasNumber(title: string): boolean {
  return /\d/.test(title);
}

function isMorningPost(title: string): boolean {
  const t = title.toLowerCase();
  const keywords = ['早报', '派早报', 'morning', '晨读', '今日早报'];
  return keywords.some(kw => t.includes(kw));
}

function hoursAgo(pubTime: string | undefined): number {
  if (!pubTime) return 48;
  const hasTimezone = /(?:Z|[+-]\d{2}:?\d{2})$/i.test(pubTime);
  const pub = new Date(hasTimezone ? pubTime : `${pubTime}Z`);
  if (Number.isNaN(pub.getTime())) return 48;
  const now = new Date();
  return Math.max(0, (now.getTime() - pub.getTime()) / (1000 * 60 * 60));
}

function calcWeight(item: typeof currentItems[0]): number {
  const title = item.title;
  let weight = 0;
  if (isMorningPost(title)) weight += 1000;
  if (hasBrandKeyword(title)) weight += 10;
  if (hasNumber(title)) weight += 5;
  const h = hoursAgo(item.pub_time);
  weight += (1 / (h + 1)) * 50;
  return weight;
}

function getItemSummary(item: typeof currentItems[0]): string {
  return item.ai_summary || item.summary;
}

function getTopicSummary(topicId: string) {
  return currentTopicSummaries.find(s => s.topic === topicId);
}

// top10 规则：权重排序 + 去重后取前10
function getTop10(items: typeof currentItems, topicId: string) {
  const topicItems = items.filter(i => i.topic === topicId);
  const seen = new Set();
  const deduped = [];
  for (const item of topicItems) {
    if (!seen.has(item.title)) {
      seen.add(item.title);
      deduped.push(item);
    }
  }
  return deduped.sort((a, b) => calcWeight(b) - calcWeight(a)).slice(0, 10);
}
---

<BaseLayout title="每日资讯 - AK22AK" description="AK22AK 关注的每日资讯聚合" variant="news">
  <div class="daily-news-layout daily-news-layout--with-summary">
    <!-- 侧边栏：板块导航 -->
    <aside class="sidebar">
      <div class="sidebar-inner">
        <h3 class="sidebar-title">📖 板块导航</h3>
        <nav class="sidebar-nav">
          {activeTopics.map(topic => (
            <a href={`#${topic.id}`} class="sidebar-link">
              <span class="sidebar-icon">{getTopicIcon(topic.id)}</span>
              <span class="sidebar-name">{topic.name}</span>
            </a>
          ))}
        </nav>
        <Calendar dates={availableDates} currentDate={currentDate} />
      </div>
    </aside>

    <!-- 主内容区 -->
    <main class="daily-main">
      <!-- 日期头部 -->
      <header class="date-header">
        <div class="date-title">
          <span class="date-icon">📰</span>
          <h1>每日资讯 {currentDate.replace(/-/g, '.')}</h1>
        </div>
        <span class="date-weekday">{currentWeekday}</span>

      </header>

      <!-- 板块内容：只展示 top10 -->
      {activeTopics.map(topic => {
        const top10 = getTop10(currentItems, topic.id);
        const topicSummary = getTopicSummary(topic.id);
        return (
          <section id={topic.id} class="topic-section">
            <div class="topic-section-header">
              <h2>
                <span class="topic-section-icon">{getTopicIcon(topic.id)}</span>
                {topic.name}
                <span class="top10-badge">TOP10</span>
              </h2>
              <a href={`/daily-news/topic/${topic.id}/?date=${currentDate}`} class="topic-more">查看全部 →</a>
            </div>

            {topicSummary && (
              <div class="topic-daily-brief topic-inline-brief">
                <p>{topicSummary.summary}</p>
                {topicSummary.highlights.length > 0 && (
                  <ul>
                    {topicSummary.highlights.map(highlight => <li>{highlight}</li>)}
                  </ul>
                )}
              </div>
            )}

            {top10.length > 0 ? (
              <div class="topic-list">
                {top10.map((item, idx) => (
                  <article class="topic-item">
                    <span class="item-rank">{idx + 1}</span>
                    <div class="item-body">
                      <h3 class="item-title">
                        <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                        <span class="item-source">{item.source}</span>
                      </h3>
                      <p class="item-summary">{getItemSummary(item)}</p>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="topic-empty">当日暂无 {topic.name} 资讯</div>
            )}
          </section>
        );
      })}

      {archivedTopics.length > 0 && (
        <section class="topic-section">
          <h2>🗄 已归档板块</h2>
          <div class="archived-grid">
            {archivedTopics.map(topic => (
              <a href={`/daily-news/topic/${topic.id}/`} class="card archived-card">
                <span class="archived-name">{topic.name}</span>
                <span class="archived-tag">已结束</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <aside class="summary-sidebar" aria-label="当前板块总结">
      <div class="summary-sidebar-inner">
        {activeTopics.map((topic, idx) => {
          const topicSummary = getTopicSummary(topic.id);
          return (
            <article class={`summary-card ${idx === 0 ? 'active' : ''}`} data-summary-topic={topic.id}>
              <div class="summary-card-header">
                <span class="summary-card-icon">{getTopicIcon(topic.id)}</span>
                <h2>{topic.name}总结</h2>
              </div>
              {topicSummary ? (
                <>
                  <div class={`summary-card-content ${topicSummary.highlights.length > 6 ? 'is-collapsed' : ''}`}>
                    <p>{topicSummary.summary}</p>
                    {topicSummary.highlights.length > 0 && (
                      <ul>
                        {topicSummary.highlights.map(highlight => <li>{highlight}</li>)}
                      </ul>
                    )}
                  </div>
                  {topicSummary.highlights.length > 6 && (
                    <button
                      type="button"
                      class="summary-card-toggle"
                      aria-expanded="false"
                    >
                      展开全部
                    </button>
                  )}
                </>
              ) : (
                <p class="summary-empty">当日暂无板块总结</p>
              )}
            </article>
          );
        })}
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('.sidebar-link[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href')!);
      if (target) target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
    });
  });

  const sections = document.querySelectorAll('.topic-section[id]');
  const sidebarLinks = document.querySelectorAll('.sidebar-link[href^="#"]');
  const summaryCards = document.querySelectorAll('.summary-card[data-summary-topic]');
  const summaryToggleButtons = document.querySelectorAll('.summary-card-toggle');

  function setActiveTopic(topicId: string) {
    sidebarLinks.forEach(link => link.classList.remove('active'));
    const activeLink = document.querySelector(`.sidebar-link[href="#${topicId}"]`);
    if (activeLink) activeLink.classList.add('active');

    summaryCards.forEach(card => {
      card.classList.toggle('active', card.getAttribute('data-summary-topic') === topicId);
    });
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setActiveTopic(entry.target.id);
      }
    });
  }, { rootMargin: '-20% 0px -60% 0px' });
  sections.forEach(section => observer.observe(section));

  summaryToggleButtons.forEach(button => {
    button.addEventListener('click', () => {
      const card = button.closest('.summary-card');
      const content = card?.querySelector('.summary-card-content');
      if (!content) return;

      const isCollapsed = content.classList.toggle('is-collapsed');
      button.textContent = isCollapsed ? '展开全部' : '收起';
      button.setAttribute('aria-expanded', String(!isCollapsed));
    });
  });
</script>
