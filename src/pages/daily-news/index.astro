---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Calendar from '../../components/Calendar.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import {
  buildSourceMeta,
  formatDateLabel,
  getClusterHeatFlames,
  getDisplayQualityReasons,
  getLeadClusters,
  getSourceName,
  getSubtopicName,
  getSubtopicIcon,
  getTopicReport,
  getTopicClusters,
  getTopicIcon,
  getTopItems,
  getWeekdayLabel,
  normalizeDailyBrief,
  normalizeStoryClusters,
  resolveClusterRefs,
  type DailyNewsData,
  type TopicConfig,
} from '../../lib/dailyNews';

const topicsPath = path.resolve('./src/data/daily-news-topics.json');
const topicsConfig = JSON.parse(fs.readFileSync(topicsPath, 'utf-8'));
const topics = topicsConfig.topics as TopicConfig[];

const newsData = await getCollection('daily-news');
const dateEntries = newsData.filter(entry => entry.id !== 'topics');
dateEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const url = new URL(Astro.request.url);
const selectedDate = url.searchParams.get('date');
const availableDates = dateEntries.map(e => e.data.date);
const currentDate = selectedDate && availableDates.includes(selectedDate)
  ? selectedDate
  : (availableDates[0] || '');
const currentEntry = dateEntries.find(e => e.data.date === currentDate);
const currentData = currentEntry?.data as DailyNewsData | undefined;
const currentItems = currentData?.items || [];
const activeTopics = topics.filter(topic => topic.active !== false);
const archivedTopics = topics.filter(topic => topic.type === 'shortterm' && topic.active === false);
const sourceMeta = buildSourceMeta(topics);
const dailyBrief = normalizeDailyBrief(currentData, activeTopics);
const storyClusters = normalizeStoryClusters(currentData, activeTopics);
const shortTermTopicIds = new Set(activeTopics.filter(topic => topic.type === 'shortterm').map(topic => topic.id));
const leadClusters = getLeadClusters(storyClusters.filter(cluster => !shortTermTopicIds.has(cluster.topic)), 4);
const currentWeekday = getWeekdayLabel(currentDate);

function topicItemCount(topicId: string) {
  return currentItems.filter(item => item.topic === topicId).length;
}

function topicSourceCount(topicId: string) {
  return new Set(currentItems.filter(item => item.topic === topicId).map(item => item.source)).size;
}
---

<BaseLayout title="每日资讯 - AK22AK" description="AK22AK 关注的每日资讯聚合" variant="news">
  <div class="daily-news-layout daily-news-layout--brief daily-news-layout--home">
    <aside class="sidebar">
      <div class="sidebar-inner">
        <h3 class="sidebar-title">板块</h3>
        <nav class="sidebar-nav" aria-label="板块导航">
          <a href="#brief" class="sidebar-link active">
            <span class="sidebar-icon">◇</span>
            <span class="sidebar-name">今日简报</span>
          </a>
          {activeTopics.map(topic => (
            <a href={`#${topic.id}`} class="sidebar-link">
              <span class="sidebar-icon">{getTopicIcon(topic.id)}</span>
              <span class="sidebar-name">{topic.name}</span>
              <span class="sidebar-count">{topicItemCount(topic.id)}</span>
            </a>
          ))}
        </nav>
        <Calendar dates={availableDates} currentDate={currentDate} />
        <div class="sidebar-footer">
          <a href={`/daily-news/sources/?date=${currentDate}`} class="sidebar-link muted">
            来源审查
          </a>
        </div>
      </div>
    </aside>

    <main class="daily-main">
      <header id="brief" class="news-brief-hero">
        <div class="brief-kicker">
          <span>{formatDateLabel(currentDate)}</span>
          {currentWeekday && <span>{currentWeekday}</span>}
          {currentData?.update_time && <span>更新 {new Date(currentData.update_time).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}</span>}
        </div>
        <h1>{dailyBrief.title}</h1>
        <p>{dailyBrief.summary || '当前日期暂无可展示的简报内容。'}</p>
        {dailyBrief.key_points.length > 0 && (
          <ol class="brief-key-points">
            {dailyBrief.key_points.map(point => <li>{point}</li>)}
          </ol>
        )}
        {leadClusters.length > 0 && (
          <div class="brief-hot-block">
            <h2>今日热门</h2>
            <div class="brief-hot-list">
            {leadClusters.map(cluster => {
              const topic = activeTopics.find(t => t.id === cluster.topic);
              const qualityReasons = getDisplayQualityReasons(cluster);
              const refItems = resolveClusterRefs(currentItems, cluster, 3);
              return (
                <article class={`brief-hot-item story-cluster-card--${cluster.importance}`}>
                  <div class="cluster-meta">
                    <span>{topic?.name || cluster.topic}</span>
                    {cluster.subtopic && <span>{getSubtopicIcon(cluster.subtopic)} {getSubtopicName(topic, cluster.subtopic)}</span>}
                    <span class="heat-chip" title="今日热度">{getClusterHeatFlames(cluster)}</span>
                  </div>
                  <h3>
                    <a href={`/daily-news/topic/${cluster.topic}/?date=${currentDate}#cluster-${cluster.id}`}>
                      {cluster.title}
                    </a>
                  </h3>
                  <p>{cluster.summary}</p>
                  {qualityReasons.length > 0 && (
                    <div class="quality-chip-row">
                      {qualityReasons.map(reason => <span>{reason}</span>)}
                    </div>
                  )}
                  {refItems.length > 0 && (
                    <details class="cluster-ref-list cluster-ref-list--compact">
                      <summary>查看 {refItems.length} 条引用</summary>
                      {refItems.map(item => (
                        <a href={item.url} target="_blank" rel="noopener noreferrer">
                          <span>{getSourceName(item.source, sourceMeta)}</span>
                          <strong>{item.title}</strong>
                        </a>
                      ))}
                    </details>
                  )}
                </article>
              );
            })}
            </div>
          </div>
        )}
      </header>

      {activeTopics.map(topic => {
        const report = getTopicReport(currentData, topic.id);
        const topicSummary = currentData?.topic_summaries?.find(summary => summary.topic === topic.id);
        const clusters = getTopicClusters(storyClusters, topic.id).slice(0, 3);
        const fallbackItems = getTopItems(currentItems.filter(item => item.topic === topic.id), 3);
        const count = topicItemCount(topic.id);
        return (
          <section id={topic.id} class="topic-section topic-overview-section">
            <div class="topic-section-header">
              <h2>
                <span class="topic-section-icon">{getTopicIcon(topic.id)}</span>
                {topic.name}
              </h2>
              <a href={`/daily-news/topic/${topic.id}/?date=${currentDate}`} class="topic-more">
                深入阅读 →
              </a>
            </div>
            <div class="topic-overview-meta">
              <span>{count} 条原始资讯</span>
              <span>{topicSourceCount(topic.id)} 个来源</span>
              {topic.subtopics?.length ? <span>{topic.subtopics.length} 个栏目</span> : <span>临时专题</span>}
            </div>
            {topic.type === 'shortterm' ? (
              <article class="topic-report-preview">
                <div class="cluster-meta">
                  <span>专题晨报</span>
                  <span>{report ? '结构化摘要' : '旧数据摘要'}</span>
                </div>
                <h3>
                  <a href={`/daily-news/topic/${topic.id}/?date=${currentDate}`}>
                    {report?.title || topicSummary?.highlights?.[0] || topic.name}
                  </a>
                </h3>
                <p>{report?.summary || topicSummary?.summary || topic.description}</p>
                {report?.sections?.length ? (
                  <div class="report-preview-grid">
                    {report.sections.slice(0, 4).map(section => <span>{section.title}</span>)}
                  </div>
                ) : topicSummary?.highlights?.length ? (
                  <div class="report-preview-grid">
                    {topicSummary.highlights.slice(0, 3).map(point => <span>{point}</span>)}
                  </div>
                ) : null}
              </article>
            ) : clusters.length > 0 ? (
              <div class="story-cluster-list story-cluster-list--compact">
                {clusters.map(cluster => {
                  const refItems = resolveClusterRefs(currentItems, cluster, 3);
                  return (
                    <article class="story-cluster-row">
                      <div class="cluster-meta">
                        {cluster.subtopic && <span>{getSubtopicIcon(cluster.subtopic)} {getSubtopicName(topic, cluster.subtopic)}</span>}
                        <span>{cluster.importance === 'lead' ? '主线' : cluster.importance === 'major' ? '重点' : '补充'}</span>
                        <span class="heat-chip" title="今日热度">{getClusterHeatFlames(cluster)}</span>
                      </div>
                      <h3>
                        <a href={`/daily-news/topic/${topic.id}/?date=${currentDate}#cluster-${cluster.id}`}>
                          {cluster.title}
                        </a>
                      </h3>
                      <p>{cluster.summary}</p>
                      {refItems.length > 0 && (
                        <details class="cluster-ref-list cluster-ref-list--compact">
                          <summary>查看 {refItems.length} 条引用</summary>
                          {refItems.map(item => (
                            <a href={item.url} target="_blank" rel="noopener noreferrer">
                              <span>{getSourceName(item.source, sourceMeta)}</span>
                              <strong>{item.title}</strong>
                            </a>
                          ))}
                        </details>
                      )}
                    </article>
                  );
                })}
              </div>
            ) : fallbackItems.length > 0 ? (
              <div class="topic-list">
                {fallbackItems.map(item => (
                  <article class="topic-item">
                    <div class="item-body">
                      <h3 class="item-title">
                        <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                        <span class="item-source">{sourceMeta.get(item.source)?.name || item.source}</span>
                      </h3>
                      <p class="item-summary">{item.ai_summary || item.summary}</p>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="topic-empty">当日暂无 {topic.name} 资讯</div>
            )}
          </section>
        );
      })}

      {archivedTopics.length > 0 && (
        <section class="topic-section">
          <h2>已归档板块</h2>
          <div class="archived-grid">
            {archivedTopics.map(topic => (
              <a href={`/daily-news/topic/${topic.id}/`} class="card archived-card">
                <span class="archived-name">{topic.name}</span>
                <span class="archived-tag">已结束</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
  </div>
</BaseLayout>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sidebarLinks = document.querySelectorAll('.sidebar-link[href^="#"]');
  const sections = document.querySelectorAll('#brief, .topic-section[id]');

  sidebarLinks.forEach(link => {
    link.addEventListener('click', (event) => {
      const href = link.getAttribute('href');
      if (!href) return;
      const target = document.querySelector(href);
      if (!target) return;
      event.preventDefault();
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' });
    });
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      sidebarLinks.forEach(link => link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`));
    });
  }, { rootMargin: '-20% 0px -65% 0px' });

  sections.forEach(section => observer.observe(section));
</script>

<style>
  #brief,
  .daily-news-layout--home .topic-section[id] {
    scroll-margin-top: 96px;
  }

  @media (max-width: 768px) {
    #brief,
    .daily-news-layout--home .topic-section[id] {
      scroll-margin-top: 72px;
    }
  }
</style>
