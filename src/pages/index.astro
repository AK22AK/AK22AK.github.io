---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AK22AK - 个人主页">
  <section style="text-align: center; padding: 3rem 0;">
    <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">👋 你好，我是 AK22AK</h1>
    <p style="font-size: 1.15rem; color: #555; max-width: 600px; margin: 0 auto 2rem;">
      这里是我的数字空间，记录我的项目、想法，以及每日关注的技术资讯。
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/projects" class="btn">查看项目</a>
      <a href="/blog" class="btn" style="background: #fff; color: #2563eb; border: 1px solid #2563eb;">阅读想法</a>
    </div>
  </section>

  <section style="margin-top: 3rem;">
    <h2>📌 快速导航</h2>
    <div class="project-grid">
      <a href="/about" class="card" style="text-decoration: none; color: inherit;">
        <h3>👤 关于我</h3>
        <p>个人简介、技能栈、联系方式等公开信息。</p>
      </a>
      <a href="/projects" class="card" style="text-decoration: none; color: inherit;">
        <h3>💻 开发项目</h3>
        <p>我在 GitHub 上的开源项目和技术实践。</p>
      </a>
      <a href="/blog" class="card" style="text-decoration: none; color: inherit;">
        <h3>📝 想法文字</h3>
        <p>技术思考、学习笔记、日常随想。</p>
      </a>
      <a href="/daily-news" class="card" style="text-decoration: none; color: inherit;">
        <h3>📰 每日新闻</h3>
        <p>我关注的技术、行业每日资讯汇总。</p>
      </a>
    </div>
  </section>
</BaseLayout>
