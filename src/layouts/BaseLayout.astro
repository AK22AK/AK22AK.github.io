---
import '../styles/global.css';
import Header from '../components/Header.astro';
import NewsHeader from '../components/NewsHeader.astro';
import Footer from '../components/Footer.astro';
import NewsFooter from '../components/NewsFooter.astro';

interface Props {
  title: string;
  description?: string;
  variant?: 'default' | 'news';
}

const { title, description = 'AK22AK 的个人主页', variant = 'default' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/ginger-emoji.png" />
    <title>{title}</title>
  </head>
  <body>
    {variant === 'news' ? <NewsHeader /> : <Header />}
    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>
    {variant === 'news' ? <NewsFooter /> : <Footer />}
  </body>
</html>
