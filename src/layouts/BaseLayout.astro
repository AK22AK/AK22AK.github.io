---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AK22AK 的个人主页' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/ginger-emoji.png" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
