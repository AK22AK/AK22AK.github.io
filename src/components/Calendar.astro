---
interface Props {
  dates: string[];
  currentDate?: string;
  baseUrl?: string;
}

const { dates, currentDate, baseUrl = '/daily-news/' } = Astro.props;
---

<div class="calendar" data-dates={JSON.stringify(dates)} data-current={currentDate || ''} data-base={baseUrl}>
  <div class="calendar-mobile-bar">
    <button class="cal-mobile-toggle" type="button" aria-label="切换日期" aria-expanded="false">
      <span aria-hidden="true">🗓</span>
    </button>
  </div>

  <div class="calendar-panel">
    <div class="calendar-header">
      <button class="cal-btn cal-prev" type="button" aria-label="上月">‹</button>
      <span class="cal-month"></span>
      <button class="cal-btn cal-next" type="button" aria-label="下月">›</button>
    </div>
    <div class="calendar-weekdays">
      <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
    </div>
    <div class="calendar-days"></div>
  </div>
</div>

<style>
  .calendar {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  .calendar-mobile-bar,
  .cal-mobile-toggle {
    display: none;
  }
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .cal-btn {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #666;
    cursor: pointer;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    line-height: 1;
  }
  .cal-btn:hover {
    background: #f3f4f6;
    color: #111;
  }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.7rem;
    color: #999;
    margin-bottom: 0.25rem;
  }
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  .calendar :global(.cal-day) {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    border-radius: 6px;
    cursor: default;
    color: #ccc;
    text-decoration: none;
  }
  .calendar :global(.cal-day.has-data) {
    color: #2563eb;
    font-weight: 600;
    cursor: pointer;
  }
  .calendar :global(.cal-day.has-data:hover) {
    background: #eff6ff;
  }
  .calendar :global(.cal-day.active) {
    background: #2563eb;
    color: #fff;
    font-weight: 600;
  }
  .calendar :global(.cal-day.active:hover) {
    background: #1d4ed8;
  }
  .calendar :global(.cal-day.today) {
    border: 1.5px solid #2563eb;
  }

  @media (max-width: 768px) {
    .calendar {
      position: relative;
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .calendar-mobile-bar {
      display: flex;
      justify-content: flex-start;
    }

    .cal-mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border: 1px solid #dbe3f0;
      border-radius: 999px;
      background: #fff;
      color: #2563eb;
      font-size: 1rem;
      line-height: 1;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .calendar.is-open .cal-mobile-toggle {
      background: #eff6ff;
    }

    .calendar-panel {
      display: none;
      position: absolute;
      top: calc(100% + 0.45rem);
      left: 0;
      z-index: 20;
      width: min(320px, calc(100vw - 2rem));
      padding: 0.75rem;
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .calendar.is-open .calendar-panel {
      display: block;
    }

    .calendar-header {
      margin-bottom: 0;
      font-size: 0.85rem;
    }

    .cal-btn {
      display: none;
    }

    .calendar-weekdays {
      display: none;
    }

    .calendar-days {
      display: flex;
      gap: 0.4rem;
      overflow-x: auto;
      padding-top: 0.5rem;
      -webkit-overflow-scrolling: touch;
    }

    .calendar :global(.cal-day) {
      display: none;
    }

    .calendar :global(.cal-day.has-data) {
      display: inline-flex;
      flex: 0 0 auto;
      min-width: 44px;
      min-height: 38px;
      aspect-ratio: auto;
      padding: 0 0.75rem;
      background: #f3f4f6;
      border-radius: 999px;
      color: #2563eb;
      font-size: 0.78rem;
    }

    .calendar :global(.cal-day.active) {
      background: #2563eb;
      color: #fff;
    }
  }
</style>

<script>
  (() => {
    document.querySelectorAll('.calendar').forEach((calendar) => {
      const dates = JSON.parse(calendar.getAttribute('data-dates') || '[]');
      const currentDate = calendar.getAttribute('data-current') || '';
      const dateSet = new Set(dates);

      const monthEl = calendar.querySelector('.cal-month');
      const daysEl = calendar.querySelector('.calendar-days');
      const prevBtn = calendar.querySelector('.cal-prev');
      const nextBtn = calendar.querySelector('.cal-next');
      const toggleBtn = calendar.querySelector('.cal-mobile-toggle');

      if (!(monthEl instanceof HTMLElement) || !(daysEl instanceof HTMLElement)) return;
      if (!(prevBtn instanceof HTMLButtonElement) || !(nextBtn instanceof HTMLButtonElement)) return;

      let year;
      let month;

      const initDate = currentDate ? new Date(`${currentDate}T00:00:00`) : new Date();
      year = initDate.getFullYear();
      month = initDate.getMonth();

      function render() {
        monthEl.textContent = `${year}年${month + 1}月`;
        daysEl.innerHTML = '';

        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const today = new Date();
        const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

        for (let i = 0; i < firstDay; i++) {
          const span = document.createElement('span');
          daysEl.appendChild(span);
        }

        for (let d = 1; d <= daysInMonth; d++) {
          const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
          const hasData = dateSet.has(dateStr);
          const isActive = dateStr === currentDate;
          const isToday = dateStr === todayStr;

          const el = document.createElement(hasData ? 'a' : 'span');
          el.className = 'cal-day';
          el.textContent = String(d);

          if (hasData) {
            el.classList.add('has-data');
            const base = calendar.getAttribute('data-base') || '/daily-news/';
            const sep = base.includes('?') ? '&' : '?';
            el.href = `${base}${sep}date=${dateStr}`;
          }

          if (isActive) el.classList.add('active');
          if (isToday && !isActive) el.classList.add('today');
          daysEl.appendChild(el);
        }
      }

      prevBtn.addEventListener('click', () => {
        month--;
        if (month < 0) {
          month = 11;
          year--;
        }
        render();
      });

      nextBtn.addEventListener('click', () => {
        month++;
        if (month > 11) {
          month = 0;
          year++;
        }
        render();
      });

      if (toggleBtn instanceof HTMLButtonElement) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = calendar.classList.toggle('is-open');
          toggleBtn.setAttribute('aria-expanded', String(isOpen));
        });
      }

      document.addEventListener('click', (event) => {
        if (!calendar.classList.contains('is-open')) return;
        if (calendar.contains(event.target)) return;
        calendar.classList.remove('is-open');
        if (toggleBtn instanceof HTMLButtonElement) {
          toggleBtn.setAttribute('aria-expanded', 'false');
        }
      });

      render();
    });
  })();
</script>
