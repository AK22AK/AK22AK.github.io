---
interface Props {
  dates: string[];  // ['2026-04-20', '2026-04-19', ...]
  currentDate?: string;
}

const { dates, currentDate } = Astro.props;
---

<div class="calendar" data-dates={JSON.stringify(dates)} data-current={currentDate || ''}>
  <div class="calendar-header">
    <button class="cal-btn cal-prev" type="button" aria-label="上月">‹</button>
    <span class="cal-month"></span>
    <button class="cal-btn cal-next" type="button" aria-label="下月">›</button>
  </div>
  <div class="calendar-weekdays">
    <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
  </div>
  <div class="calendar-days"></div>
</div>

<style>
  .calendar {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .cal-btn {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #666;
    cursor: pointer;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    line-height: 1;
  }
  .cal-btn:hover {
    background: #f3f4f6;
    color: #111;
  }
  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.7rem;
    color: #999;
    margin-bottom: 0.25rem;
  }
  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    border-radius: 6px;
    cursor: default;
    color: #ccc;
    text-decoration: none;
  }
  .cal-day.has-data {
    color: #2563eb;
    font-weight: 600;
    cursor: pointer;
  }
  .cal-day.has-data:hover {
    background: #eff6ff;
  }
  .cal-day.active {
    background: #2563eb;
    color: #fff;
    font-weight: 600;
  }
  .cal-day.active:hover {
    background: #1d4ed8;
  }
  .cal-day.today {
    border: 1.5px solid #2563eb;
  }
</style>

<script>
  (function() {
    const calendar = document.querySelector('.calendar');
    if (!calendar) return;

    const dates: string[] = JSON.parse(calendar.getAttribute('data-dates') || '[]');
    const currentDate = calendar.getAttribute('data-current') || '';
    const dateSet = new Set(dates);

    const monthEl = calendar.querySelector('.cal-month') as HTMLElement;
    const daysEl = calendar.querySelector('.calendar-days') as HTMLElement;
    const prevBtn = calendar.querySelector('.cal-prev') as HTMLButtonElement;
    const nextBtn = calendar.querySelector('.cal-next') as HTMLButtonElement;

    let year: number, month: number;

    // 初始显示当前月份（优先取 currentDate 所在月，或今天）
    const initDate = currentDate ? new Date(currentDate + 'T00:00:00') : new Date();
    year = initDate.getFullYear();
    month = initDate.getMonth();

    function render() {
      monthEl.textContent = `${year}年${month + 1}月`;
      daysEl.innerHTML = '';

      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const today = new Date();
      const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

      // 空白占位
      for (let i = 0; i < firstDay; i++) {
        const span = document.createElement('span');
        daysEl.appendChild(span);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const hasData = dateSet.has(dateStr);
        const isActive = dateStr === currentDate;
        const isToday = dateStr === todayStr;

        const el = document.createElement(hasData ? 'a' : 'span');
        el.className = 'cal-day';
        el.textContent = String(d);

        if (hasData) {
          el.classList.add('has-data');
          (el as HTMLAnchorElement).href = `/daily-news/?date=${dateStr}`;
        }
        if (isActive) el.classList.add('active');
        if (isToday && !isActive) el.classList.add('today');

        daysEl.appendChild(el);
      }
    }

    prevBtn.addEventListener('click', () => {
      month--;
      if (month < 0) { month = 11; year--; }
      render();
    });

    nextBtn.addEventListener('click', () => {
      month++;
      if (month > 11) { month = 0; year++; }
      render();
    });

    render();
  })();
</script>
